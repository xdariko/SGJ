MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9eae88fb23cd44843a4b2027ecc3248a, type: 3}
  m_Name: metamorphosis_02
  m_EditorClassIdentifier: Assembly-CSharp::StorySequenceData
  id: metamorphosis_02
  lines:
  - text: "\u041F\u043E\u0431\u0435\u0436\u0434\u0451\u043D\u043D\u044B\u0439 \u043C\u0443\u0442\u0430\u043D\u0442
      \u0440\u0443\u0445\u043D\u0443\u043B \u043D\u0430 \u043F\u043E\u043B."
    image: {fileID: 0}
  - text: "\u0415\u0433\u043E \u043A\u043E\u0441\u0442\u044F\u043D\u0430\u044F \u0440\u0443\u043A\u0430
      \u0434\u0451\u0440\u043D\u0443\u043B\u0430\u0441\u044C \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439
      \u0440\u0430\u0437."
    image: {fileID: 0}
  - text: "\u041A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E, \u043E\u043D\u0430
      \u0434\u0451\u0440\u043D\u0443\u043B\u0430\u0441\u044C \u0432 \u0441\u0442\u043E\u0440\u043E\u043D\u0443
      \u0422\u0438\u043C\u0430."
    image: {fileID: 0}
  - text: "\u2014 \u041D\u0435\u0442. \u041D\u0435 \u043D\u0430\u0434\u043E. \u0423
      \u043C\u0435\u043D\u044F \u0443\u0436\u0435 \u0435\u0441\u0442\u044C \u043E\u0434\u043D\u0430
      \u0441\u0442\u0440\u0430\u043D\u043D\u0430\u044F \u0440\u0443\u043A\u0430."
    image: {fileID: 0}
  - text: "\u041B\u0435\u0432\u0430\u044F \u0440\u0443\u043A\u0430 \u0445\u0440\u0443\u0441\u0442\u043D\u0443\u043B\u0430.
      \u041A\u043E\u0441\u0442\u0438 \u0432\u044B\u0442\u044F\u043D\u0443\u043B\u0438\u0441\u044C
      \u043D\u0430\u0440\u0443\u0436\u0443, \u043F\u0430\u043B\u044C\u0446\u044B
      \u0441\u043E\u0433\u043D\u0443\u043B\u0438\u0441\u044C \u0432 \u043A\u0440\u044E\u0447\u044C\u044F,
      \u0441\u0443\u0441\u0442\u0430\u0432\u044B \u0440\u0435\u0448\u0438\u043B\u0438
      \u0436\u0438\u0442\u044C \u0441\u0432\u043E\u0435\u0439 \u0436\u0438\u0437\u043D\u044C\u044E."
    image: {fileID: 0}
  - text: "\u0427\u0435\u0440\u0435\u0437 \u043F\u0430\u0440\u0443 \u0441\u0435\u043A\u0443\u043D\u0434
      \u0432\u043C\u0435\u0441\u0442\u043E \u0440\u0443\u043A\u0438 \u0431\u044B\u043B\u0430
      \u0434\u043B\u0438\u043D\u043D\u0430\u044F \u043A\u043E\u0441\u0442\u044F\u043D\u0430\u044F
      \u043A\u043B\u0435\u0448\u043D\u044F."
    image: {fileID: 0}
  - text: "\u0422\u0438\u043C \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E
      \u0449\u0451\u043B\u043A\u043D\u0443\u043B \u0435\u0439 \u0432 \u0432\u043E\u0437\u0434\u0443\u0445\u0435."
    image: {fileID: 0}
  - text: "\u2014 \u0410\u0433\u0430. \u0422\u0435\u043F\u0435\u0440\u044C \u0443
      \u043C\u0435\u043D\u044F \u0435\u0441\u0442\u044C \u0440\u0435\u0436\u0438\u043C
      \u201C\u0438\u0434\u0438 \u0441\u044E\u0434\u0430, \u0433\u0430\u0434\u201D."
    image: {fileID: 0}
  - text: "\u041D\u041E\u0412\u041E\u0415 \u0423\u041C\u0415\u041D\u0418\u0415\n\u041F\u0440\u0438\u0442\u044F\u0433\u0438\u0432\u0430\u0439
      \u043C\u0435\u043B\u043A\u0438\u0445 \u0432\u0440\u0430\u0433\u043E\u0432 \u043A
      \u0441\u0435\u0431\u0435 \u0438 \u043E\u0433\u043B\u0443\u0448\u0430\u0439
      \u0438\u0445.  \n\u0423\u0434\u043E\u0431\u043D\u043E, \u043C\u0435\u0440\u0437\u043A\u043E,
      \u043E\u043F\u0430\u0441\u043D\u043E. \u0412 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u043C
      \u0434\u043B\u044F \u043D\u0438\u0445."
    image: {fileID: 0}
  - text: "\u0423\u041F\u0420\u0410\u0412\u041B\u0415\u041D\u0418\u0415\n\u041F\u041A\u041C
      \u2014 \u043A\u043E\u0441\u0442\u044F\u043D\u043E\u0439 \u043A\u0440\u044E\u043A"
    image: {fileID: 0}
