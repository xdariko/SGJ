  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9eae88fb23cd44843a4b2027ecc3248a, type: 3}
  m_Name: final_01
  m_EditorClassIdentifier: Assembly-CSharp::StorySequenceData
  id: final_01
  lines:
  - text: "\u041C\u0443\u0442\u0430\u043D\u0442 \u0440\u0443\u0445\u043D\u0443\u043B. 
      \n\u041A\u043E\u0440\u0430\u0431\u043B\u044C \u043D\u0430\u043A\u043E\u043D\u0435\u0446
      \u0437\u0430\u0442\u0438\u0445."
    image: {fileID: 0}
  - text: "\u0422\u0438\u043C \u0432\u044B\u0434\u043E\u0445\u043D\u0443\u043B."
    image: {fileID: 0}
  - text: "\u041F\u043E\u0442\u043E\u043C \u0441\u0442\u0435\u043D\u044B \u043D\u0430\u0447\u0430\u043B\u0438
      \u0434\u044B\u0448\u0430\u0442\u044C."
    image: {fileID: 0}
  - text: "\u041E\u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C, \u043F\u0430\u0440\u0430\u0437\u0438\u0442
      \u0437\u0430\u0440\u0430\u0437\u0438\u043B \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E
      \u044D\u043A\u0438\u043F\u0430\u0436.  \n\u041E\u043D \u0437\u0430\u0440\u0430\u0437\u0438\u043B
      \u0432\u0435\u0441\u044C \u043A\u043E\u0440\u0430\u0431\u043B\u044C."
    image: {fileID: 0}
  - text: "\u0413\u043B\u0430\u0432\u043D\u044B\u0439 \u043A\u043E\u043C\u043F\u044C\u044E\u0442\u0435\u0440
      \u043F\u0440\u043E\u0445\u0440\u0438\u043F\u0435\u043B: **\u201C\u042D\u041A\u0418\u041F\u0410\u0416
      \u0421\u041E\u0425\u0420\u0410\u041D\u0401\u041D.\u201D**"
    image: {fileID: 0}
  - text: "\u0422\u0438\u043C \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u043B
      \u043D\u0430 \u0441\u0435\u0431\u044F."
    image: {fileID: 0}
  - text: "\u2014 \u0421\u043B\u043E\u0432\u043E \u201C\u0441\u043E\u0445\u0440\u0430\u043D\u0451\u043D\u201D
      \u0442\u0443\u0442 \u043E\u0447\u0435\u043D\u044C \u0441\u043F\u043E\u0440\u043D\u043E\u0435."
    image: {fileID: 0}
  - text: "\u0421\u043F\u0430\u0441\u0430\u0442\u0435\u043B\u044C\u043D\u0430\u044F
      \u043A\u0430\u043F\u0441\u0443\u043B\u0430 \u043E\u0442\u043A\u0440\u044B\u043B\u0430\u0441\u044C
      \u0441\u0430\u043C\u0430.  \n\u041F\u043E\u0437\u0430\u0434\u0438 \u0447\u0442\u043E-\u0442\u043E
      \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435 \u043D\u0430\u0447\u0430\u043B\u043E
      \u043F\u043E\u043B\u0437\u0442\u0438 \u043F\u043E \u043A\u043E\u0440\u0438\u0434\u043E\u0440\u0443."
    image: {fileID: 0}
  - text: "\u0422\u0438\u043C \u0437\u0430\u043B\u0435\u0437 \u0432\u043D\u0443\u0442\u0440\u044C
      \u0438 \u043D\u0430\u0436\u0430\u043B \u0437\u0430\u043F\u0443\u0441\u043A.\n\n\u2014
      \u0412\u0441\u0451. \u0411\u043E\u043B\u044C\u043D\u0438\u0447\u043D\u044B\u0439.
      \u0423\u0432\u043E\u043B\u044C\u043D\u0435\u043D\u0438\u0435. \u041F\u0441\u0438\u0445\u043E\u043B\u043E\u0433.
      \u0412 \u043B\u044E\u0431\u043E\u043C \u043F\u043E\u0440\u044F\u0434\u043A\u0435."
    image: {fileID: 0}
  - text: "\u041A\u0430\u043F\u0441\u0443\u043B\u0430 \u0443\u043B\u0435\u0442\u0435\u043B\u0430
      \u0432 \u043A\u043E\u0441\u043C\u043E\u0441."
    image: {fileID: 0}
  - text: "\u041A\u041E\u041D\u0415\u0426"
    image: {fileID: 0}
