MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9eae88fb23cd44843a4b2027ecc3248a, type: 3}
  m_Name: metamorphosis_01
  m_EditorClassIdentifier: Assembly-CSharp::StorySequenceData
  id: metamorphosis_01
  lines:
  - text: "\u0412\u0434\u0440\u0443\u0433 \u043F\u0440\u0430\u0432\u0430\u044F \u0440\u0443\u043A\u0430
      \u043D\u0430\u0447\u0430\u043B\u0430 \u0433\u043E\u0440\u0435\u0442\u044C.  "
    image: {fileID: 0}
  - text: "\u041F\u043E\u0442\u043E\u043C \u043F\u0443\u043B\u044C\u0441\u0438\u0440\u043E\u0432\u0430\u0442\u044C.  "
    image: {fileID: 0}
  - text: "\u041F\u043E\u0442\u043E\u043C \u0438\u0437\u0434\u0430\u0432\u0430\u0442\u044C
      \u0437\u0432\u0443\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
      \u0440\u0443\u043A\u0430 \u0438\u0437\u0434\u0430\u0432\u0430\u0442\u044C \u043D\u0435
      \u0434\u043E\u043B\u0436\u043D\u0430."
    image: {fileID: 0}
  - text: "\u041F\u0430\u043B\u044C\u0446\u044B \u0441\u043B\u0438\u043F\u043B\u0438\u0441\u044C.
      \n\u041A\u043E\u0436\u0430 \u0432\u0437\u0434\u0443\u043B\u0430\u0441\u044C.\n\u041B\u0430\u0434\u043E\u043D\u044C
      \u0440\u0430\u0441\u043A\u0440\u044B\u043B\u0430\u0441\u044C, \u043A\u0430\u043A
      \u043C\u043E\u043A\u0440\u0430\u044F \u043F\u0430\u0441\u0442\u044C."
    image: {fileID: 0}
  - text: "\u0422\u0438\u043C \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u043B
      \u043D\u0430 \u0440\u0443\u043A\u0443.  "
    image: {fileID: 0}
  - text: "\u0420\u0443\u043A\u0430 \u0431\u0443\u043B\u044C\u043A\u043D\u0443\u043B\u0430."
    image: {fileID: 0}
  - text: "\u2014 \u041E\u0442\u043B\u0438\u0447\u043D\u043E. \u042F \u0441\u0442\u0430\u043B
      \u0432\u043E\u0434\u044F\u043D\u044B\u043C \u043F\u0438\u0441\u0442\u043E\u043B\u0435\u0442\u043E\u043C
      \u0438\u0437 \u043A\u043E\u0448\u043C\u0430\u0440\u0430."
    image: {fileID: 0}
  - text: "\u041D\u041E\u0412\u041E\u0415 \u0423\u041C\u0415\u041D\u0418\u0415\n\u0421\u0442\u0440\u0435\u043B\u044F\u0439
      \u0441\u043B\u0438\u0437\u044C\u044E \u0438 \u0437\u0430\u043C\u0435\u0434\u043B\u044F\u0439
      \u0432\u0440\u0430\u0433\u043E\u0432.  \n\u041C\u0435\u0440\u0437\u043A\u043E,
      \u043D\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442."
    image: {fileID: 0}
  - text: "\u0423\u041F\u0420\u0410\u0412\u041B\u0415\u041D\u0418\u0415\nE \u2014
      \u0441\u043C\u0435\u043D\u0430 \u0430\u0442\u0430\u043A\u0438\n\u041B\u041A\u041C
      \u2014 \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u0442\u044C"
    image: {fileID: 0}
